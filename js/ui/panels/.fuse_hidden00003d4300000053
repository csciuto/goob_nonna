import { Knob } from '../components/knob.js';
import { SwitchControl } from '../components/switch-control.js';
import { Jack } from '../components/jack.js';
import { WAVEFORMS, OCTAVE_FEET, PATCH_POINTS } from '../../utils/constants.js';

/**
 * Oscillators panel: OSC1 + OSC2 side by side.
 */
export class PanelOscillators {
  constructor({ onJackClick }) {
    this.element = document.createElement('div');
    this.element.className = 'panel panel-oscillators';

    this.jacks = {};

    // Two-column grid: OSC1 left, OSC2 right
    const grid = document.createElement('div');
    grid.className = 'osc-grid';

    // --- Headers ---
    const h1 = document.createElement('h3');
    h1.textContent = 'OSC 1';
    const h2 = document.createElement('h3');
    h2.textContent = 'OSC 2';
    grid.appendChild(h1);
    grid.appendChild(h2);

    // --- Row 1: WAVE OUT jacks ---
    this.jacks.osc1WaveOut = new Jack({ id: PATCH_POINTS.OSC1_WAVE_OUT, type: 'output', label: 'WAVE OUT', onClick: onJackClick });
    this.jacks.osc2WaveOut = new Jack({ id: PATCH_POINTS.OSC2_WAVE_OUT, type: 'output', label: 'WAVE OUT', onClick: onJackClick });
    this.jacks.osc1WaveOut.getElement().dataset.tooltip = 'Raw audio output from oscillator 1';
    this.jacks.osc2WaveOut.getElement().dataset.tooltip = 'Raw audio output from oscillator 2';
    grid.appendChild(this.jacks.osc1WaveOut.getElement());
    grid.appendChild(this.jacks.osc2WaveOut.getElement());

    // --- Row 2: PITCH IN + PWM IN (osc1) | PITCH IN + LIN FM (osc2) ---
    this.jacks.osc1PitchIn = new Jack({ id: PATCH_POINTS.OSC1_PITCH_IN, type: 'input', label: 'PITCH IN', onClick: onJackClick });
    this.jacks.osc1PwmIn = new Jack({ id: PATCH_POINTS.OSC1_PWM_IN, type: 'input', label: 'PWM IN', onClick: onJackClick });
    this.jacks.osc2PitchIn = new Jack({ id: PATCH_POINTS.OSC2_PITCH_IN, type: 'input', label: 'PITCH IN', onClick: onJackClick });
    this.jacks.osc2LinFmIn = new Jack({ id: PATCH_POINTS.OSC2_LIN_FM_IN, type: 'input', label: 'LIN FM IN', onClick: onJackClick });
    this.jacks.osc1PitchIn.getElement().dataset.tooltip = 'CV input to control oscillator 1 pitch';
    this.jacks.osc1PwmIn.getElement().dataset.tooltip = 'Modulates the pulse width of oscillator 1';
    this.jacks.osc2PitchIn.getElement().dataset.tooltip = 'CV input to control oscillator 2 pitch';
    this.jacks.osc2LinFmIn.getElement().dataset.tooltip = 'Linear FM input for oscillator 2';

    const jackPair1 = document.createElement('div');
    jackPair1.className = 'jack-pair';
    jackPair1.appendChild(this.jacks.osc1PitchIn.getElement());
    jackPair1.appendChild(this.jacks.osc1PwmIn.getElement());

    const jackPair2 = document.createElement('div');
    jackPair2.className = 'jack-pair';
    jackPair2.appendChild(this.jacks.osc2PitchIn.getElement());
    jackPair2.appendChild(this.jacks.osc2LinFmIn.getElement());

    grid.appendChild(jackPair1);
    grid.appendChild(jackPair2);

    // --- Row 4: OCTAVE switches ---
    this.osc1Octave = new SwitchControl({
      label: 'OCT',
      positions: OCTAVE_FEET.map(f => ({ value: f, label: `${f}'` })),
      selectedIndex: 2,
    });
    this.osc2Octave = new SwitchControl({
      label: 'OCT',
      positions: OCTAVE_FEET.map(f => ({ value: f, label: `${f}'` })),
      selectedIndex: 2,
    });
    this.osc1Octave.getElement().dataset.tooltip = 'Shifts oscillator 1 pitch by octaves — 8\' is normal';
    this.osc2Octave.getElement().dataset.tooltip = 'Shifts oscillator 2 pitch by octaves';
    grid.appendChild(this.osc1Octave.getElement());
    grid.appendChild(this.osc2Octave.getElement());

    // --- Row 5: SYNC button (osc1) | FREQ knob (osc2) ---
    this.syncButton = document.createElement('button');
    this.syncButton.className = 'sync-button';
    this.syncButton.textContent = 'SYNC';
    this.syncButton.dataset.tooltip = 'Hard-syncs OSC2 to OSC1 for harmonic timbres';
    this._syncEnabled = false;

    this.syncButton.addEventListener('click', () => {
      this._syncEnabled = !this._syncEnabled;
      this.syncButton.classList.toggle('active', this._syncEnabled);
      if (this._onSyncChange) this._onSyncChange(this._syncEnabled);
    });

    const syncCell = document.createElement('div');
    syncCell.className = 'sync-cell';
    syncCell.appendChild(this.syncButton);

    this.osc2Freq = new Knob({
      label: 'FREQ',
      min: -7,
      max: 7,
      value: 0,
      step: 0.1,
      bipolar: true,
    });
    this.osc2Freq.getElement().dataset.tooltip = 'Fine-tunes oscillator 2 — detune slightly from OSC1 for thickness';
    grid.appendChild(syncCell);
    grid.appendChild(this.osc2Freq.getElement());

    // --- Row 6: WAVEFORM switches ---
    this.osc1Waveform = new SwitchControl({
      label: 'WAVE',
      positions: [
        { value: WAVEFORMS.TRIANGLE, label: '△' },
        { value: WAVEFORMS.SAW, label: '⊿' },
        { value: WAVEFORMS.SQUARE, label: '⊓' },
        { value: WAVEFORMS.NARROW_PULSE, label: '⊔' },
      ],
      selectedIndex: 1,
    });
    this.osc2Waveform = new SwitchControl({
      label: 'WAVE',
      positions: [
        { value: WAVEFORMS.TRIANGLE, label: '△' },
        { value: WAVEFORMS.SAW, label: '⊿' },
        { value: WAVEFORMS.SQUARE, label: '⊓' },
        { value: WAVEFORMS.NARROW_PULSE, label: '⊔' },
      ],
      selectedIndex: 1,
    });
    this.osc1Waveform.getElement().dataset.tooltip = 'Selects the raw waveform shape for oscillator 1';
    this.osc2Waveform.getElement().dataset.tooltip = 'Selects the raw waveform shape for oscillator 2';
    grid.appendChild(this.osc1Waveform.getElement());
    grid.appendChild(this.osc2Waveform.getElement());

    this.element.appendChild(grid);
  }

  wire(engine) {
    this.osc1Waveform.onChange = (v) => engine.setOsc1Waveform(v);
    this.osc1Octave.onChange = (v) => engine.setOsc1Octave(v);

    this.osc2Waveform.onChange = (v) => engine.setOsc2Waveform(v);
    this.osc2Octave.onChange = (v) => engine.setOsc2Octave(v);
    this.osc2Freq.onChange = (v) => engine.setOsc2Detune(v);
    this._onSyncChange = (v) => engine.setOsc2Sync(v);
  }

  getElement() { return this.element; }
}
