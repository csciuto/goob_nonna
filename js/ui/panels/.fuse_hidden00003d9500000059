import { Knob } from '../components/knob.js';
import { Jack } from '../components/jack.js';
import { PATCH_POINTS } from '../../utils/constants.js';

export class PanelUtilities {
  constructor({ onJackClick }) {
    this.element = document.createElement('div');
    this.element.className = 'panel panel-utilities';
    this.element.innerHTML = '<h3>UTILITIES</h3>';

    this.jacks = {};

    // Mult: 2x2 grid of jacks with connecting lines
    const multSection = document.createElement('div');
    multSection.className = 'mult-section';

    this.jacks.mult1 = new Jack({ id: PATCH_POINTS.MULT_1, type: 'output', label: 'MULT', onClick: onJackClick });
    this.jacks.mult2 = new Jack({ id: PATCH_POINTS.MULT_2, type: 'output', label: 'MULT', onClick: onJackClick });
    this.jacks.mult3 = new Jack({ id: PATCH_POINTS.MULT_3, type: 'input', label: 'MULT', onClick: onJackClick });
    this.jacks.mult4 = new Jack({ id: PATCH_POINTS.MULT_4, type: 'input', label: 'MULT', onClick: onJackClick });
    this.jacks.mult1.getElement().dataset.tooltip = 'Mult — all 4 jacks are connected, splits one signal into copies';
    this.jacks.mult2.getElement().dataset.tooltip = 'Mult — all 4 jacks are connected';
    this.jacks.mult3.getElement().dataset.tooltip = 'Mult — all 4 jacks are connected';
    this.jacks.mult4.getElement().dataset.tooltip = 'Mult — all 4 jacks are connected';

    const multGrid = document.createElement('div');
    multGrid.className = 'mult-grid';
    multGrid.appendChild(this.jacks.mult1.getElement());
    multGrid.appendChild(this.jacks.mult2.getElement());
    multGrid.appendChild(this.jacks.mult3.getElement());
    multGrid.appendChild(this.jacks.mult4.getElement());

    // SVG lines drawing a square through the jacks
    const multLines = document.createElementNS('http://www.w3.org/2000/svg', 'svg');
    multLines.setAttribute('class', 'mult-lines');
    multLines.innerHTML = '<line x1="25%" y1="30%" x2="75%" y2="30%"/><line x1="75%" y1="30%" x2="75%" y2="70%"/><line x1="75%" y1="70%" x2="25%" y2="70%"/><line x1="25%" y1="70%" x2="25%" y2="30%"/>';
    multGrid.appendChild(multLines);

    multSection.appendChild(multGrid);
    this.element.appendChild(multSection);

    // HPF: knob then input/output jacks
    this.hpfCutoff = new Knob({ label: 'CUTOFF', min: 0, max: 10, value: 5 });
    this.hpfCutoff.getElement().dataset.tooltip = 'Cutoff frequency for the high-pass filter';
    this.element.appendChild(this.hpfCutoff.getElement());

    this.jacks.hpfIn = new Jack({ id: PATCH_POINTS.HPF_IN, type: 'input', label: 'INPUT', onClick: onJackClick });
    this.jacks.hpfOut = new Jack({ id: PATCH_POINTS.HPF_OUT, type: 'output', label: 'OUTPUT', onClick: onJackClick });
    this.jacks.hpfIn.getElement().dataset.tooltip = 'Audio input to the high-pass filter';
    this.jacks.hpfOut.getElement().dataset.tooltip = 'Filtered audio output from the high-pass filter';
    this.jacks.hpfOut.getElement().classList.add('jack-output-label');

    const hpfJacks = document.createElement('div');
    hpfJacks.className = 'jack-row jack-row-top';
    hpfJacks.appendChild(this.jacks.hpfIn.getElement());
    hpfJacks.appendChild(this.jacks.hpfOut.getElement());
    this.element.appendChild(hpfJacks);

    // Attenuator: knob then input/output jacks
    this.attenAmount = new Knob({ label: 'ATTEN', min: -10, max: 10, value: 10, bipolar: true });
    this.attenAmount.getElement().dataset.tooltip = 'Scales or inverts a signal passing through';
    this.element.appendChild(this.attenAmount.getElement());

    this.jacks.attenIn = new Jack({ id: PATCH_POINTS.ATTEN_IN, type: 'input', label: 'INPUT', onClick: onJackClick });
    this.jacks.attenOut = new Jack({ id: PATCH_POINTS.ATTEN_OUT, type: 'output', label: 'OUTPUT', onClick: onJackClick });
    this.jacks.attenIn.getElement().dataset.tooltip = 'Signal input to the attenuator — normalled to DC';
    this.jacks.attenOut.getElement().dataset.tooltip = 'Scaled signal output from the attenuator';
    this.jacks.attenOut.getElement().classList.add('jack-output-label');

    const attenJacks = document.createElement('div');
    attenJacks.className = 'jack-row jack-row-top';
    attenJacks.appendChild(this.jacks.attenIn.getElement());
    attenJacks.appendChild(this.jacks.attenOut.getElement());
    this.element.appendChild(attenJacks);
  }

  wire(engine) {
    this.hpfCutoff.onChange = (v) => engine.setHPFCutoff(v / 10);
    this.attenAmount.onChange = (v) => engine.setAttenuatorAmount(v / 10);
  }

  getElement() { return this.element; }
}
