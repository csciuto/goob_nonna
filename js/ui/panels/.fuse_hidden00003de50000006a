import { Knob } from '../components/knob.js';
import { SwitchControl } from '../components/switch-control.js';
import { Jack } from '../components/jack.js';
import { PATCH_POINTS, KB_TRACK } from '../../utils/constants.js';

export class PanelFilter {
  constructor({ onJackClick }) {
    this.element = document.createElement('div');
    this.element.className = 'panel panel-filter';
    this.element.innerHTML = '<h3>FILTER</h3>';

    this.jacks = {};

    // Row 1: INPUT (left), OUTPUT (right) — spread wide
    this.jacks.filterIn = new Jack({ id: PATCH_POINTS.FILTER_IN, type: 'input', label: 'INPUT', onClick: onJackClick });
    this.jacks.filterOut = new Jack({ id: PATCH_POINTS.FILTER_OUT, type: 'output', label: 'OUTPUT', onClick: onJackClick });
    this.jacks.filterIn.getElement().dataset.tooltip = 'Audio input to the filter — normalled to mixer output';
    this.jacks.filterOut.getElement().dataset.tooltip = 'Filtered audio output';
    this.jacks.filterOut.getElement().classList.add('jack-output-label');

    const jackRow1 = document.createElement('div');
    jackRow1.className = 'jack-row jack-row-top filter-jacks-wide';
    jackRow1.appendChild(this.jacks.filterIn.getElement());
    jackRow1.appendChild(this.jacks.filterOut.getElement());
    this.element.appendChild(jackRow1);

    // Row 2: ENV AMT IN, CUTOFF IN — closer to center (V shape)
    this.jacks.envAmtIn = new Jack({ id: PATCH_POINTS.ENV_AMT_IN, type: 'input', label: 'ENV AMT', onClick: onJackClick });
    this.jacks.cutoffIn = new Jack({ id: PATCH_POINTS.CUTOFF_IN, type: 'input', label: 'CUTOFF IN', onClick: onJackClick });
    this.jacks.envAmtIn.getElement().dataset.tooltip = 'CV input to modulate envelope amount';
    this.jacks.cutoffIn.getElement().dataset.tooltip = 'CV input to modulate filter cutoff frequency';

    const jackRow2 = document.createElement('div');
    jackRow2.className = 'jack-row jack-row-top filter-jacks-narrow';
    jackRow2.appendChild(this.jacks.envAmtIn.getElement());
    jackRow2.appendChild(this.jacks.cutoffIn.getElement());
    this.element.appendChild(jackRow2);

    // Big CUTOFF knob — value displays as frequency
    this.cutoff = new Knob({ label: 'CUTOFF', min: 0, max: 10, value: 7, step: 0.1 });
    this.cutoff.getElement().dataset.tooltip = 'Controls which frequencies pass through — sweep this first';
    this.cutoff.getElement().classList.add('filter-cutoff-knob');

    // Override value display to show frequency
    const origUpdate = this.cutoff._updateVisual.bind(this.cutoff);
    this.cutoff._updateVisual = () => {
      origUpdate();
      const norm = this.cutoff.value / 10;
      const freq = 20 * Math.pow(1000, norm);
      if (freq >= 1000) {
        this.cutoff._valueEl.textContent = `${(freq / 1000).toFixed(1)} kHz`;
      } else {
        this.cutoff._valueEl.textContent = `${Math.round(freq)} Hz`;
      }
    };
    this.cutoff._updateVisual();

    this.element.appendChild(this.cutoff.getElement());

    // Connecting line to KB TRACK
    const connectLine = document.createElement('div');
    connectLine.className = 'filter-connect-line';
    this.element.appendChild(connectLine);

    // KB TRACK switch
    this.kbTrack = new SwitchControl({
      label: 'KB TRACK',
      positions: [
        { value: KB_TRACK.HALF, label: '1:2' },
        { value: KB_TRACK.OFF, label: 'OFF' },
        { value: KB_TRACK.FULL, label: '1:1' },
      ],
      selectedIndex: 2,
    });
    this.kbTrack.getElement().dataset.tooltip = 'Filter follows keyboard pitch — higher notes sound brighter';
    this.element.appendChild(this.kbTrack.getElement());

    // Bottom row: ENV AMT + RESONANCE knobs
    this.envAmt = new Knob({ label: 'EG AMT', min: -5, max: 5, value: 0, step: 0.1, bipolar: true });
    this.resonance = new Knob({ label: 'RES', min: 0, max: 4, value: 0, step: 0.1 });
    this.envAmt.getElement().dataset.tooltip = 'How much the envelope opens/closes the filter per note';
    this.resonance.getElement().dataset.tooltip = 'Boosts frequencies at the cutoff — self-oscillates at max';

    const bottomRow = document.createElement('div');
    bottomRow.className = 'knob-row';
    bottomRow.appendChild(this.envAmt.getElement());
    bottomRow.appendChild(this.resonance.getElement());
    this.element.appendChild(bottomRow);
  }

  wire(engine) {
    this.cutoff.onChange = (v) => engine.setFilterCutoff(v / 10);
    this.resonance.onChange = (v) => engine.setFilterResonance(v);
    this.envAmt.onChange = (v) => engine.setFilterEnvAmount(v / 5);
    this.kbTrack.onChange = (v) => engine.setFilterKbTrack(v);
  }

  getElement() { return this.element; }
}
