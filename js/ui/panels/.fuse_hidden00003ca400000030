import { Knob } from '../components/knob.js';
import { SwitchControl } from '../components/switch-control.js';
import { LED } from '../components/led.js';
import { Jack } from '../components/jack.js';
import { PATCH_POINTS, LFO_WAVEFORMS } from '../../utils/constants.js';

export class PanelModulation {
  constructor({ onJackClick }) {
    this.element = document.createElement('div');
    this.element.className = 'panel panel-modulation';
    this.element.innerHTML = '<h3>MODULATION</h3>';

    this.jacks = {};

    // Row 1: RATE IN (left), WAVE OUT (right)
    this.jacks.lfoRateIn = new Jack({ id: PATCH_POINTS.LFO_RATE_IN, type: 'input', label: 'RATE IN', onClick: onJackClick });
    this.jacks.lfoWaveOut = new Jack({ id: PATCH_POINTS.LFO_WAVE_OUT, type: 'output', label: 'WAVE OUT', onClick: onJackClick });
    this.jacks.lfoRateIn.getElement().dataset.tooltip = 'CV input to modulate LFO speed';
    this.jacks.lfoWaveOut.getElement().dataset.tooltip = 'Selected LFO waveform output';

    const jackRow1 = document.createElement('div');
    jackRow1.className = 'jack-row jack-row-top';
    jackRow1.appendChild(this.jacks.lfoRateIn.getElement());
    jackRow1.appendChild(this.jacks.lfoWaveOut.getElement());
    this.element.appendChild(jackRow1);

    // Row 2: SYNC IN, S/H OUT (centered)
    this.jacks.lfoSyncIn = new Jack({ id: PATCH_POINTS.LFO_SYNC_IN, type: 'input', label: 'SYNC IN', onClick: onJackClick });
    this.jacks.lfoShOut = new Jack({ id: PATCH_POINTS.LFO_SH_OUT, type: 'output', label: 'S/H OUT', onClick: onJackClick });
    this.jacks.lfoSyncIn.getElement().dataset.tooltip = 'Trigger input to reset LFO phase';
    this.jacks.lfoShOut.getElement().dataset.tooltip = 'LFO sample & hold output — random stepped values';

    const jackRow2 = document.createElement('div');
    jackRow2.className = 'jack-row jack-row-top';
    jackRow2.appendChild(this.jacks.lfoSyncIn.getElement());
    jackRow2.appendChild(this.jacks.lfoShOut.getElement());
    this.element.appendChild(jackRow2);

    // Row 3: RATE knob with LED below
    this.lfoRate = new Knob({ label: 'RATE', min: 0, max: 10, value: 5 });
    this.lfoRate.getElement().dataset.tooltip = 'Speed of the low-frequency oscillator';
    this.led = new LED();

    const rateSection = document.createElement('div');
    rateSection.className = 'rate-section';
    rateSection.appendChild(this.lfoRate.getElement());
    rateSection.appendChild(this.led.getElement());
    this.element.appendChild(rateSection);

    // Row 4: PITCH AMT, CUTOFF AMT
    this.pitchAmt = new Knob({ label: 'PITCH AMT', min: 0, max: 10, value: 0 });
    this.cutoffAmt = new Knob({ label: 'CUTOFF AMT', min: 0, max: 10, value: 0 });
    this.pitchAmt.getElement().dataset.tooltip = 'How much the LFO wobbles pitch (vibrato) via mod wheel';
    this.cutoffAmt.getElement().dataset.tooltip = 'How much the LFO wobbles the filter (wah) via mod wheel';

    const row4 = document.createElement('div');
    row4.className = 'knob-row';
    row4.appendChild(this.pitchAmt.getElement());
    row4.appendChild(this.cutoffAmt.getElement());
    this.element.appendChild(row4);

    // Row 5: PW AMT, WAVEFORM
    this.pwAmt = new Knob({ label: 'PW AMT', min: 0, max: 10, value: 0 });
    this.pwAmt.getElement().dataset.tooltip = 'How much the LFO modulates pulse width via mod wheel';

    this.lfoWaveform = new SwitchControl({
      label: 'WAVEFORM',
      positions: [
        { value: LFO_WAVEFORMS.TRIANGLE, label: 'TRI' },
        { value: LFO_WAVEFORMS.SQUARE, label: 'SQR' },
        { value: LFO_WAVEFORMS.SAWTOOTH, label: 'SAW' },
        { value: LFO_WAVEFORMS.RAMP, label: 'RAMP' },
        { value: LFO_WAVEFORMS.SAMPLE_HOLD, label: 'S/H' },
      ],
      selectedIndex: 0,
    });
    this.lfoWaveform.getElement().dataset.tooltip = 'Shape of the LFO waveform';

    const row5 = document.createElement('div');
    row5.className = 'knob-row';
    row5.appendChild(this.pwAmt.getElement());
    row5.appendChild(this.lfoWaveform.getElement());
    this.element.appendChild(row5);
  }

  wire(engine) {
    this.lfoRate.onChange = (v) => engine.setLFORate(v);
    this.lfoWaveform.onChange = (v) => engine.setLFOWaveform(v);
    this.pitchAmt.onChange = (v) => engine.setPitchAmount(v / 10);
    this.cutoffAmt.onChange = (v) => engine.setCutoffAmount(v / 10);
    this.pwAmt.onChange = (v) => engine.setPWAmount(v / 10);

    // Wire LFO LED — blink at LFO rate
    this._engine = engine;
    this._animateLED();
  }

  _animateLED() {
    if (!this._engine) return;
    const val = this._engine.getLFOValue();
    // LED on when LFO value is positive
    this.led.setOn(val > 0);
    this._ledFrame = requestAnimationFrame(() => this._animateLED());
  }

  getElement() { return this.element; }
}
