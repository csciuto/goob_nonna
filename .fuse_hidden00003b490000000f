/* Goob Nonna - Synthesizer Styles */

* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
}

body {
  background: #141a14;
  color: #e8e4dc;
  font-family: 'Courier New', monospace;
  overflow-x: hidden;
  min-width: 1280px;
  user-select: none;
}

/* Synth Container */
#synth {
  max-width: 1600px;
  margin: 0 auto;
  padding: 10px;
}

/* Header */
.synth-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 10px 20px;
  background: #1e2e1e;
  border-bottom: 2px solid #2a4a2a;
  margin-bottom: 5px;
}

.synth-header h1 {
  font-size: 26px;
  letter-spacing: 6px;
  color: #e8e4dc;
  font-weight: normal;
}

.header-controls {
  display: flex;
  align-items: center;
  gap: 14px;
}

.guide-link {
  color: #8a2828;
  text-decoration: none;
  font-size: 14px;
  letter-spacing: 1px;
  padding: 5px 10px;
  border: 1px solid #3a5a3a;
  border-radius: 3px;
  transition: background 0.1s;
}

.guide-link:hover {
  background: #243824;
  color: #e8e4dc;
}

.preset-selector select {
  background: #243824;
  color: #e8e4dc;
  border: 1px solid #3a5a3a;
  padding: 5px 10px;
  font-family: inherit;
  font-size: 14px;
  cursor: pointer;
}

/* Panel Area */
.panel-area {
  position: relative;
  background: #e0daca;
  border: 2px solid #2a4a2a;
  padding: 5px;
  min-height: 400px;
}

/* Panel Row */
.panel-row {
  display: flex;
  gap: 2px;
  align-items: stretch;
}

/* Individual Panel */
.panel {
  background: #d6d0c0;
  border: 1px solid #a09880;
  padding: 8px;
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 6px;
}

.panel h3 {
  font-size: 12px;
  text-align: center;
  color: #2a2418;
  letter-spacing: 2px;
  text-transform: uppercase;
  border-bottom: 1px solid #a09880;
  padding-bottom: 3px;
  margin-bottom: 2px;
}

.panel h4 {
  font-size: 11px;
  color: #5a5040;
  letter-spacing: 1px;
  text-transform: uppercase;
  margin-top: 4px;
}

.panel-section {
  border-top: 1px solid #b0a890;
  padding-top: 4px;
}

.panel-controller {
  flex: 0 0 80px;
}

.panel-oscillators {
  flex: 0 0 200px;
}

.panel-kb-jacks {
  flex: 0 0 80px;
}

.panel-arp-seq {
  flex: 0 0 150px;
}

/* Knob */
.knob-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 2px;
}

.knob {
  width: 40px;
  height: 40px;
  border-radius: 50%;
  background: #1e2e1e;
  border: 2px solid #0e1a0e;
  position: relative;
  cursor: grab;
  transition: box-shadow 0.1s;
}

.knob:hover {
  box-shadow: 0 0 6px rgba(122, 154, 112, 0.4);
}

.knob.active {
  cursor: grabbing;
  box-shadow: 0 0 8px rgba(122, 154, 112, 0.6);
}

.knob-pointer {
  position: absolute;
  top: 3px;
  left: 50%;
  width: 2px;
  height: 14px;
  background: #e8e4dc;
  transform: translateX(-50%);
  border-radius: 1px;
}

.knob-label {
  font-size: 10px;
  color: #2a2418;
  text-transform: uppercase;
  letter-spacing: 1px;
  text-align: center;
}

.knob-value {
  font-size: 9px;
  color: #5a5040;
  text-align: center;
}

/* Switch Control */
.switch-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 2px;
}

.switch-label {
  font-size: 10px;
  color: #2a2418;
  text-transform: uppercase;
  letter-spacing: 1px;
}

.switch-body {
  display: flex;
  gap: 1px;
  background: #0e1a0e;
  border-radius: 3px;
  padding: 1px;
}

.switch-option {
  font-size: 9px;
  padding: 3px 5px;
  color: #6a8a60;
  cursor: pointer;
  border-radius: 2px;
  text-transform: uppercase;
  letter-spacing: 0.5px;
  transition: all 0.1s;
}

.switch-option:hover {
  color: #b0c8a8;
}

.switch-option.active {
  background: #2a4a2a;
  color: #e8e4dc;
}

/* Slider (ADSR) */
.slider-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 2px;
}

.slider-label {
  font-size: 10px;
  color: #2a2418;
  text-transform: uppercase;
  font-weight: bold;
}

.slider-track {
  width: 16px;
  height: 80px;
  background: #0e1a0e;
  border-radius: 3px;
  position: relative;
  cursor: pointer;
}

.slider-fill {
  position: absolute;
  bottom: 0;
  left: 0;
  width: 100%;
  background: #4a6a40;
  border-radius: 0 0 3px 3px;
  pointer-events: none;
}

.slider-thumb {
  position: absolute;
  left: -3px;
  width: 22px;
  height: 8px;
  background: #e8e4dc;
  border: 1px solid #2a2418;
  border-radius: 2px;
  transform: translateY(50%);
  pointer-events: none;
}

.sliders-row {
  display: flex;
  gap: 8px;
  justify-content: center;
}

/* Jack */
.jack-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 2px;
}

.jack {
  width: 24px;
  height: 24px;
  border-radius: 50%;
  background: #0e1a0e;
  border: 2px solid #2a4a2a;
  cursor: pointer;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: border-color 0.1s;
}

.jack:hover {
  border-color: #e8e4dc;
}

.jack-output {
  border-color: #8a2828;
}

.jack-input {
  border-color: #3a6a3a;
}

.jack-hole {
  width: 10px;
  height: 10px;
  border-radius: 50%;
  background: #060a06;
}

.jack.connected {
  box-shadow: 0 0 4px rgba(122, 154, 112, 0.5);
}

.jack-label {
  font-size: 8px;
  color: #5a5040;
  text-transform: uppercase;
  text-align: center;
  max-width: 40px;
  line-height: 1.2;
}

.jack-row {
  display: flex;
  gap: 6px;
  flex-wrap: wrap;
  justify-content: center;
  padding-top: 4px;
  border-top: 1px solid #b0a890;
  margin-top: auto;
}

/* Button */
.button-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 2px;
}

.synth-button {
  width: 28px;
  height: 28px;
  border-radius: 4px;
  background: #243824;
  border: 2px solid #1e2e1e;
  cursor: pointer;
  transition: all 0.1s;
}

.synth-button:hover {
  background: #2e4a2e;
}

.synth-button.active {
  background: #8a2828;
  border-color: #aa3333;
}

.button-label {
  font-size: 9px;
  color: #2a2418;
  text-transform: uppercase;
}

.buttons-row {
  display: flex;
  gap: 4px;
  justify-content: center;
  align-items: center;
}

/* LED */
.led {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  background: #3a1010;
  border: 1px solid #2a0808;
  transition: background 0.1s;
}

.led.on {
  background: var(--led-color, #ff0000);
  box-shadow: 0 0 6px var(--led-color, #ff0000);
}

/* Wheel */
.wheel-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 2px;
}

.wheel-label {
  font-size: 10px;
  color: #e8e4dc;
  text-transform: uppercase;
  letter-spacing: 1px;
}

.wheel-track {
  width: 22px;
  height: 100px;
  background: #0e1a0e;
  border-radius: 4px;
  position: relative;
  cursor: pointer;
}

.wheel-thumb {
  position: absolute;
  left: -2px;
  width: 26px;
  height: 16px;
  background: #3a5a3a;
  border: 1px solid #1e2e1e;
  border-radius: 3px;
  transform: translateY(50%);
  pointer-events: none;
}

/* Keyboard Area — wheels sit alongside keyboard */
.keyboard-area {
  margin-top: 5px;
  padding: 8px;
  background: #1e2e1e;
  border: 2px solid #2a4a2a;
  display: flex;
  align-items: stretch;
  gap: 12px;
}

.keyboard-wheels {
  display: flex;
  gap: 8px;
  align-items: center;
  padding: 4px 6px;
  flex-shrink: 0;
}

.keyboard {
  display: flex;
  position: relative;
  height: 120px;
  justify-content: center;
  flex: 1;
}

.key {
  position: relative;
  cursor: pointer;
  transition: background 0.05s;
}

.white-key {
  width: 36px;
  height: 120px;
  background: #f5f2eb;
  border: 1px solid #999;
  border-radius: 0 0 3px 3px;
  z-index: 1;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  padding-bottom: 4px;
}

.white-key:hover {
  background: #eae6dd;
}

.white-key.active {
  background: #ddd8cc;
}

.black-key {
  width: 22px;
  height: 75px;
  background: #1a1a1a;
  border: 1px solid #111;
  border-radius: 0 0 2px 2px;
  margin-left: -11px;
  margin-right: -11px;
  z-index: 2;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  padding-bottom: 3px;
}

.black-key .key-label {
  color: #777;
}

.black-key:hover {
  background: #2a2a2a;
}

.black-key.active {
  background: #3a3a3a;
}

.key-label {
  font-size: 8px;
  color: #888;
  pointer-events: none;
}

/* Patch Cable Overlay */
.patch-cable-overlay {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  pointer-events: none;
  z-index: 100;
}

.patch-cable {
  pointer-events: stroke;
  cursor: pointer;
  stroke-linecap: round;
  filter: drop-shadow(0 2px 2px rgba(0, 0, 0, 0.3));
}

.patch-cable:hover {
  stroke-width: 6 !important;
  filter: drop-shadow(0 2px 4px rgba(0, 0, 0, 0.5));
}

.patch-cable.pending {
  stroke-dasharray: 8 4;
  opacity: 0.7;
}

/* Responsive adjustments */
@media (max-width: 1400px) {
  .panel-row {
    flex-wrap: wrap;
  }

  .panel {
    min-width: 120px;
  }
}
